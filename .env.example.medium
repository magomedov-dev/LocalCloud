# ── LocalCloud — пресет для СРЕДНЕГО хоста (2 CPU / 4 ГБ ОЗУ / 128 ГБ диск) ────
# Готовый профиль для тестового/небольшого production-сервера.
#   cp .env.example.medium .env   # затем отредактируйте секреты
#   docker compose up -d --build
#
# Базовый профиль (1 CPU / 1 ГБ) — .env.example / .env.example.small. Под другое
# железо считайте значения по docs/env-tuning-guide.md.
# Отличия от базового: 2 uvicorn-worker'а, больший пул БД и backpressure, 2
# параллельных рендера превью, поднятые лимиты превью и архивов под 128 ГБ диск,
# увеличенные mem_limit и тюнинг Postgres под 4 ГБ. Все возможности UI включены.
APP_NAME=LocalCloud
APP_VERSION=0.1.0
APP_DESCRIPTION=Веб-приложение для персонального хранения файлов
DEBUG=false

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true
LOG_FILE_ENABLED=false

# ── Database (пул подключений приложения) ────────────────────────────────────
POSTGRES_USER=localcloud
POSTGRES_PASSWORD=localcloud_change_me_in_production
POSTGRES_DB=localcloud
POSTGRES_ECHO=false
# Пул на ОДИН процесс. Реальное число коннектов в кластере:
#   (UVICORN_WORKERS + 1 worker) * (POSTGRES_POOL_SIZE + POSTGRES_MAX_OVERFLOW)
#   = (2 + 1) * (10 + 5) = 45  < POSTGRES_MAX_CONNECTIONS=80 (с запасом).
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=5
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=1800
POSTGRES_POOL_PRE_PING=true

# ── MinIO / S3 ──────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=localcloud
MINIO_SECRET_KEY=localcloud_change_me_in_production
MINIO_SECURE=false
MINIO_REGION=us-east-1
MINIO_PUBLIC_HOST=localhost
MINIO_PUBLIC_PORT=80
# 128 ГБ диск: отдаём под пул хранилища ~110 ГБ (оставляя место под временные
# ZIP-файлы, логи и систему). Закомментируйте, чтобы определять автоматически
# (85% от ёмкости тома MinIO).
STORAGE_CAPACITY_BYTES=118111600640
# 2 ядра: 8 потоков под MinIO SDK дают параллелизм без лишних переключений.
STORAGE_EXECUTOR_MAX_WORKERS=8

# ── Security ────────────────────────────────────────────────────────────────
SECRET_KEY=localcloud-secret-key-in-production-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ISSUER=localcloud
JWT_AUDIENCE=localcloud
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_HASH_SCHEME=bcrypt

# ── Cookies ─────────────────────────────────────────────────────────────────
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
COOKIE_SECURE=false
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
COOKIE_PATH=/

# ── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@localcloud.dev
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@LocalCloud123

# ── Uvicorn (API-сервер) ─────────────────────────────────────────────────────
# 2 ядра → 2 процесса API (каждый ~120–180 МБ, свой пул БД).
UVICORN_WORKERS=2

# ── Backpressure (защита API от перегрузки) ──────────────────────────────────
# Больше RAM/CPU → выше потолок одновременных запросов.
MAX_CONCURRENT_REQUESTS=128
REQUEST_TIMEOUT_SECONDS=90

# ── Preview generation (фоновый рендер миниатюр) ─────────────────────────────
PREVIEW_GENERATION_ENABLED=true
# 4 ГБ ОЗУ позволяют обрабатывать более крупные источники.
PREVIEW_IMAGE_MAX_SOURCE_MB=60
PREVIEW_PDF_MAX_SOURCE_MB=80
PREVIEW_VIDEO_MAX_SOURCE_MB=256
# 2 ядра → допускаем 2 параллельных тяжёлых рендера.
PREVIEW_RENDER_CONCURRENCY=2
# Чуть чётче превью, чем на слабом хосте (больше RAM на рендер допустимо).
PREVIEW_IMAGE_MAX_DIMENSION=512
PREVIEW_IMAGE_QUALITY=80
PREVIEW_IMAGE_MAX_PIXELS=60000000
PREVIEW_PDF_RENDER_DPI=144
PREVIEW_PDF_RENDER_MAX_DIM=2048
PREVIEW_VIDEO_FFMPEG_TIMEOUT_SECONDS=45

# ── Archives (фоновая сборка ZIP папок) ──────────────────────────────────────
# 128 ГБ диск: можно собирать заметно большие архивы (нужно свободное место
# под временный ZIP, ~ARCHIVE_MAX_TOTAL_MB * ARCHIVE_DISK_SAFETY_FACTOR).
ARCHIVE_MAX_FILES=50000
ARCHIVE_MAX_TOTAL_MB=16384
ARCHIVE_STREAM_CHUNK_BYTES=4194304
ARCHIVE_DISK_SAFETY_FACTOR=1.1

# ── Feature flags (возможности UI; отдаются фронтенду через GET /config) ──────
FEATURE_PREVIEWS_ENABLED=true
FEATURE_FILE_VIEWER_ENABLED=true
FEATURE_MEDIA_PLAYBACK_ENABLED=true
FEATURE_FILE_EDITING_ENABLED=true

# ── Resource limits (лимиты контейнеров; читаются docker-compose.yml) ─────────
# Бюджет ~4 ГБ: postgres 1g + minio 1g + api 1g + worker 768m + frontend 64m +
# nginx 64m ≈ 3.9 ГБ (с запасом под пики). cpu_shares — относительный вес при
# конкуренции за 2 ядра; worker намеренно ниже, чтобы рендеры не вытесняли API.
POSTGRES_MEM_LIMIT=1g
POSTGRES_CPU_SHARES=1024
MINIO_MEM_LIMIT=1g
MINIO_CPU_SHARES=768
API_MEM_LIMIT=1g
API_CPU_SHARES=1024
WORKER_MEM_LIMIT=768m
WORKER_CPU_SHARES=256
FRONTEND_MEM_LIMIT=64m
FRONTEND_CPU_SHARES=256
NGINX_MEM_LIMIT=64m
NGINX_CPU_SHARES=512

# ── Postgres server tuning (флаги сервера; читаются docker-compose.yml) ───────
# max_connections ≥ суммарный пул приложения (45) + запас. shared_buffers ≈ 25%
# от POSTGRES_MEM_LIMIT (1 ГБ → 256 МБ).
POSTGRES_MAX_CONNECTIONS=80
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=768MB
POSTGRES_WORK_MEM=8MB
POSTGRES_MAINTENANCE_WORK_MEM=96MB
POSTGRES_MAX_WORKER_PROCESSES=4
POSTGRES_MAX_PARALLEL_WORKERS=2
POSTGRES_MAX_PARALLEL_WORKERS_PER_GATHER=1
