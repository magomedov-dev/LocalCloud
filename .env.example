# ── LocalCloud ──────────────────────────────────────────────────────────────
# Канонический шаблон конфигурации. Скопируйте в .env и отредактируйте секреты:
#   cp .env.example .env
#
# Значения по умолчанию рассчитаны на МАЛЕНЬКИЙ хост (1 CPU / 1 ГБ ОЗУ, ~3
# пользователя) — стек работает «из коробки» и не валит машину.
#
# Готовые пресеты под другое железо:
#   • .env.example.small   — слабый хост   (1 CPU / 1 ГБ)   — то же, что здесь
#   • .env.example.medium  — средний хост  (2 CPU / 4 ГБ / 128 ГБ)
# Под произвольные характеристики считайте значения по формулам:
#   docs/env-tuning-guide.md
APP_NAME=LocalCloud
APP_VERSION=0.1.0
APP_DESCRIPTION=Веб-приложение для персонального хранения файлов
DEBUG=false

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true
LOG_FILE_ENABLED=false

# ── Database (пул подключений приложения) ────────────────────────────────────
POSTGRES_USER=localcloud
POSTGRES_PASSWORD=localcloud_change_me_in_production
POSTGRES_DB=localcloud
POSTGRES_ECHO=false
# Пул на ОДИН процесс. Реальное число коннектов в кластере:
#   (UVICORN_WORKERS + 1 worker) * (POSTGRES_POOL_SIZE + POSTGRES_MAX_OVERFLOW)
# Держите его ниже POSTGRES_MAX_CONNECTIONS (см. ниже) с запасом ~10.
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=5
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=1800
POSTGRES_POOL_PRE_PING=true

# ── MinIO / S3 ──────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=localcloud
MINIO_SECRET_KEY=localcloud_change_me_in_production
MINIO_SECURE=false
MINIO_REGION=us-east-1
MINIO_PUBLIC_HOST=localhost
MINIO_PUBLIC_PORT=80
# Общая ёмкость пула хранилища в байтах для выдачи квот. Если не задана, пул
# определяется автоматически как 85% от ёмкости диска, которую видит MinIO.
# Если задать больше, чем физически доступно в MinIO, бэкенд упадёт на старте.
# STORAGE_CAPACITY_BYTES=536870912000
# Пул потоков под блокирующий MinIO SDK (presigned/object-операции). На 1 ядре
# 4 достаточно; больше лишь добавляет переключений контекста и стеков потоков.
STORAGE_EXECUTOR_MAX_WORKERS=4

# ── Security ────────────────────────────────────────────────────────────────
SECRET_KEY=localcloud-secret-key-in-production-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ISSUER=localcloud
JWT_AUDIENCE=localcloud
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_HASH_SCHEME=bcrypt

# ── Cookies ─────────────────────────────────────────────────────────────────
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
COOKIE_SECURE=false
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
COOKIE_PATH=/

# ── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@localcloud.dev
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@LocalCloud123

# ── Uvicorn (API-сервер) ─────────────────────────────────────────────────────
# Число процессов API. Каждый worker — отдельный процесс Python (~120–180 МБ) со
# своим пулом БД. На 1 ядре держите 1; масштабируйте вместе с CPU.
UVICORN_WORKERS=1

# ── Backpressure (защита API от перегрузки) ──────────────────────────────────
# Потолок одновременно обрабатываемых запросов; сверх него API отдаёт 503
# (Retry-After), не давая очереди расти и выедать память/коннекты.
MAX_CONCURRENT_REQUESTS=64
# Таймаут обработчика запроса в секундах (стриминг/скачивание не ограничивает —
# тело отдаётся уже после возврата обработчика). Защищает от зависших запросов.
REQUEST_TIMEOUT_SECONDS=90
# Потолок одновременных per-node операций в thumbnail-батче (UoW + проверка
# доступа). Бережёт пул БД при опросе миниатюр большими папками. Держите ниже
# пула БД (POSTGRES_POOL_SIZE + MAX_OVERFLOW), оставляя запас другим запросам.
THUMBNAIL_BATCH_CONCURRENCY=6

# ── Preview generation (фоновый рендер миниатюр) ─────────────────────────────
# Мастер-флаг генерации превью. false — на совсем слабых серверах: worker не
# скачивает и не рендерит файлы (помечает NOT_REQUIRED), экономя RAM/CPU.
PREVIEW_GENERATION_ENABLED=true
# Источник скачивается потоково во временный файл (без загрузки в RAM целиком),
# но сам рендер всё равно ест память. Файлы крупнее лимита превью не получают
# (помечаются NOT_REQUIRED). Дефолты — под 1 ГБ ОЗУ; на мощном хосте поднимайте.
# ЭМПИРИКА (замерено): пик anon-памяти worker при рендере PDF ≈
#   127 + 3.1 × PREVIEW_PDF_MAX_SOURCE_MB (МиБ, при MALLOC_ARENA_MAX=2).
# При PDF=30 это ≈220 МиБ → worker (лимит 220m) падал по OOM. PDF=10 → ≈158 МиБ,
# уверенно влезает в 220m. Картинки дёшевы (+~10 МиБ), видео — кадр через ffmpeg.
PREVIEW_IMAGE_MAX_SOURCE_MB=25
PREVIEW_PDF_MAX_SOURCE_MB=10
PREVIEW_VIDEO_MAX_SOURCE_MB=80
# Сколько тяжёлых рендеров (PDF/видео/картинки) идёт одновременно. 1 на 1 ядре:
# параллельные рендеры бессмысленны и грозят OOM. Поднимайте вместе с CPU/RAM.
PREVIEW_RENDER_CONCURRENCY=1
# Параметры качества/размера растров (влияют на RAM рендера и вес миниатюры).
# Дефолты экономны; на мощном хосте можно поднять размер/DPI для чётких превью.
PREVIEW_IMAGE_MAX_DIMENSION=400
PREVIEW_IMAGE_QUALITY=75
# Предел Pillow на число пикселей растра (защита от «decompression bomb»).
PREVIEW_IMAGE_MAX_PIXELS=40000000
PREVIEW_PDF_RENDER_DPI=120
PREVIEW_PDF_RENDER_MAX_DIM=1600
# Таймаут вызова ffmpeg при извлечении кадра из видео, секунды.
PREVIEW_VIDEO_FFMPEG_TIMEOUT_SECONDS=30

# ── Archives (фоновая сборка ZIP папок) ──────────────────────────────────────
# ZIP собирается во временный файл на диске и потоково отдаётся в MinIO (память
# не зависит от размера архива). Лимиты защищают от заполнения диска временным
# файлом и от слишком большого списка записей. Проверяются ДО начала сборки.
ARCHIVE_MAX_FILES=10000
# Максимальный суммарный размер исходных файлов в архиве, МБ (оценка сверху для
# ZIP). Также требуется столько же свободного места на диске (с запасом ~10%).
ARCHIVE_MAX_TOTAL_MB=2048
# Размер блока потоковой передачи объекта в ZIP (байты). Пик RAM на файл ≈ один
# блок; больше — быстрее, но прожорливее по памяти.
ARCHIVE_STREAM_CHUNK_BYTES=1048576
# Множитель запаса свободного места на диске относительно суммарного размера
# источников (1.1 = +10%). ZIP уже сжатых данных ≈ исходный размер.
ARCHIVE_DISK_SAFETY_FACTOR=1.1

# ── Feature flags (возможности UI; отдаются фронтенду через GET /config) ──────
# Позволяют отключить функциональность на слабых/ограниченных серверах. Бэкенд
# использует PREVIEW_GENERATION_ENABLED (генерация), а флаги ниже управляют тем,
# что показывает фронтенд.
# Показывать ли preview-миниатюры в файловом гриде.
FEATURE_PREVIEWS_ENABLED=true
# Открывать ли просмотрщик содержимого файлов (изображения/PDF/текст и т.д.).
FEATURE_FILE_VIEWER_ENABLED=true
# Проигрывать ли аудио/видео внутри просмотрщика (иначе предлагается скачать).
FEATURE_MEDIA_PLAYBACK_ENABLED=true
# Разрешать ли редактирование текстовых файлов в просмотрщике.
FEATURE_FILE_EDITING_ENABLED=true

# ── Resource limits (лимиты контейнеров; читаются docker-compose.yml) ─────────
# *_MEM_LIMIT — жёсткий потолок памяти контейнера (swap отключён: memswap=mem).
#   При превышении ядро убивает именно этот контейнер, и он перезапускается.
# *_CPU_SHARES — относительный вес CPU при конкуренции за ядра (по умолчанию
#   1024). worker намеренно ниже, чтобы рендеры превью не вытесняли API/БД.
#
# Пресеты (ориентир; подгоняйте под реальную нагрузку):
#   ┌────────────┬───────────────────────────────────────────────────────────┐
#   │ Хост        │ Рекомендации                                              │
#   ├────────────┼───────────────────────────────────────────────────────────┤
#   │ 1CPU/1ГБ    │ значения по умолчанию ниже (UVICORN_WORKERS=1, пул 5+5)    │
#   │ 2CPU/4ГБ    │ см. .env.example.medium (UVICORN_WORKERS=2, пул 10+5,      │
#   │            │ POSTGRES_MAX_CONNECTIONS=80, shared_buffers=256MB)        │
#   │ другое      │ считайте по docs/env-tuning-guide.md                      │
#   └────────────┴───────────────────────────────────────────────────────────┘
POSTGRES_MEM_LIMIT=220m
POSTGRES_CPU_SHARES=1024
MINIO_MEM_LIMIT=256m
MINIO_CPU_SHARES=768
API_MEM_LIMIT=220m
API_CPU_SHARES=1024
WORKER_MEM_LIMIT=220m
WORKER_CPU_SHARES=256
FRONTEND_MEM_LIMIT=32m
FRONTEND_CPU_SHARES=256
NGINX_MEM_LIMIT=40m
NGINX_CPU_SHARES=512

# ── Postgres server tuning (флаги сервера; читаются docker-compose.yml) ───────
# Держите max_connections ≥ суммарного пула приложения (формула выше) + запас.
# shared_buffers ≈ 25–30% от POSTGRES_MEM_LIMIT.
POSTGRES_MAX_CONNECTIONS=50
POSTGRES_SHARED_BUFFERS=64MB
POSTGRES_EFFECTIVE_CACHE_SIZE=160MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAINTENANCE_WORK_MEM=32MB
POSTGRES_MAX_WORKER_PROCESSES=2
POSTGRES_MAX_PARALLEL_WORKERS=1
POSTGRES_MAX_PARALLEL_WORKERS_PER_GATHER=0
